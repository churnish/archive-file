{
  "name": "archive-file",
  "version": "0.1.0",
  "description": "Move the current file to an archive folder.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "css": "true",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.52.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "knip": "^5.85.0",
    "obsidian": "^1.11.4",
    "prettier": "^3.8.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "knip": {
    "entry": [
      "main.ts"
    ],
    "project": [
      "**/*.ts"
    ],
    "ignoreDependencies": ["prettier"],
    "ignoreBinaries": ["tsc", "knip"],
    "ignoreExportsUsedInFile": true
  }
}
